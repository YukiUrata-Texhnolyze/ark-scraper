    END
    Text.ParseText.ParseForFirstOccurrence Text: tmp_soldout[LoopIndex] TextToFind: $'''〜''' StartingPosition: 0 IgnoreCase: False OccurrencePosition=> Variation_exit
    IF Variation_exit > (-1) THEN
