# メール送信設定 (Office365 SMTP)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=urata@texhnolyze.biz
SMTP_PASS=your_password_here

# メール送受信先
MAIL_FROM=urata@texhnolyze.biz
MAIL_TO=urata@ark-pc.co.jp
MAIL_CC=k_ishii@ark-pc.co.jp

# CSV出力先ディレクトリ (デフォルト: ./output)
OUTPUT_DIR=./output

# WDを途中から再開したい場合の範囲指定
# WD_PRODUCT_OFFSET=0
# WD_PRODUCT_LIMIT=0

# ブラウザ表示モード (false でブラウザを表示してデバッグ可能)
HEADLESS=true

# Amazonのみ永続プロファイルを使いたい場合
# AMAZON_PERSISTENT_USER_DATA_DIR=./.playwright/amazon-profile

# Amazonプロファイル育成時に開くURLを上書きしたい場合
# AMAZON_PROFILE_TARGET_URL=https://www.amazon.co.jp/

# Amazon のお届け先郵便番号を指定したい場合
# AMAZON_DELIVERY_POSTAL_CODE=2720031

# amazon:profile を自動終了したい場合 (ミリ秒)
# AMAZON_SETUP_AUTO_CLOSE_MS=10000

# Ark メモリ / SSD スクレイパー設定
# 既存の no-arg 実行には含まれません。`ark-memory` / `ark-ssd` を明示して実行してください。
# ARK_MEMORY_URL=https://www.ark-pc.co.jp/search/?category=c21&col=5&limit=50&order=1&p1=b21020&p3=h21830%3Ah21571&p5=s21010&p6=w11728%3Aw11729%3Aw11730%3Aw11731%3Aw11732
# ARK_MEMORY_URLS=https://www.ark-pc.co.jp/search/?category=c21&col=5&limit=50&order=1&p1=b21020&p3=h21830%3Ah21571&p5=s21010&p6=w11728%3Aw11729%3Aw11730%3Aw11731%3Aw11732,https://www.ark-pc.co.jp/search/?category=c21&col=3&key=288pin%20DDR5-&limit=50&p1=b21010&p2=c21060&p3=h21830%3Ah21850&p4=p21098%3Ap21205%3Ap21099%3Ap21097%3Ap21096&p5=s21010
# ARK_SSD_URL=https://www.ark-pc.co.jp/search/?col=3&label_code=KIOXIA&limit=50&p1=b32020&p3=h32032&p4=p32030%3Ap32040
# ARK_SSD_URLS=https://www.ark-pc.co.jp/search/?col=3&label_code=KIOXIA&limit=50&p1=b32020&p3=h32032&p4=p32030%3Ap32040,https://www.ark-pc.co.jp/search/?col=3&label_code=Princeton&limit=50&p1=b32020&p3=h32032&p4=p32030%3Ap32040,https://www.ark-pc.co.jp/search/?col=3&label_code=SAMSUNG&limit=50&p1=b32020&p3=h32032&p4=p32030%3Ap32040,https://www.ark-pc.co.jp/search/?col=3&label_code=Western%20Digital&limit=50&p1=b32020&p3=h32032&p4=p32030%3Ap32040,https://www.ark-pc.co.jp/search/?col=3&key=SNV&label_code=Kingston&limit=50&p1=b32020&p3=h32032&p4=p32030%3Ap32040&search_target=on
# ARK_ARTIFACT_DIR=./playwright-artifacts
# ARK_STORAGE_STATE_PATH=./playwright-artifacts/ark-storage.json
# ARK_TIMEOUT_MS=60000
# ARK_MEMORY_MAX_PAGES=0
# ARK_DEBUG=false
# ARK_MEMORY_R2_KEY=ark_csv/ark-memory-latest.csv
# ARK_SSD_R2_KEY=ark_csv/ark-ssd-latest.csv

# Ark を Cloudflare R2 にアップロードしたい場合
# AWS_* でも R2_* でも指定できます
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your-access-key-id
# R2_SECRET_ACCESS_KEY=your-secret-access-key
# R2_BUCKET=your-bucket-name
# R2_REGION=auto

# SharePoint へ成果物をアップロードしたい場合
# Azure AD / Entra ID のアプリ登録で Microsoft Graph Files.ReadWrite.All / Sites.ReadWrite.All 相当の権限が必要
# SHAREPOINT_TENANT_ID=your-tenant-id
# SHAREPOINT_CLIENT_ID=your-client-id
# SHAREPOINT_CLIENT_SECRET=your-client-secret
# SHAREPOINT_SITE_URL=https://texhnolyzebiz.sharepoint.com/sites/texhnolyze.biz
# SHAREPOINT_FOLDER_PATH=/Shared Documents/General/本間様用
